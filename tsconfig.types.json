{
  // Declaration-only files: emit .d.ts, never a (would-be empty) .js.
  // types.ts -- public response types. protocol.ts -- worker wire contract
  // (its .d.ts ships so client.d.ts can reference it).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true
  },
  "include": ["types.ts", "protocol.ts"]
}
